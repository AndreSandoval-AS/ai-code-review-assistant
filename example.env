# =============================================================================
# PR / Code Review Assistant — configuration template
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values:   cp example.env .env
# `.env` is gitignored — never commit real keys.
# Every setting the app reads is documented below.
# =============================================================================

# --- LLM provider selection --------------------------------------------------
# Which provider runs *primary* inference. The chain is written once and is
# provider-agnostic; switching this is the only change needed to swap vendors.
# Options: groq | gemini | openai | anthropic
LLM_PROVIDER=groq

# --- Groq (primary inference) ------------------------------------------------
# Free API key: https://console.groq.com  (Settings -> API Keys)
GROQ_API_KEY=
# Open-weight GPT-OSS on Groq. Large = best quality; for lower latency/cost use
# the smaller model:  openai/gpt-oss-20b
GROQ_MODEL=openai/gpt-oss-120b

# --- Google Gemini (cross-provider fallback) ---------------------------------
# Free API key: https://ai.google.dev  (Get API key)
# Used automatically when the primary provider errors out (.withFallbacks).
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI / Anthropic (optional — only if LLM_PROVIDER is set to them) ------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- Retrieval / RAG tuning --------------------------------------------------
# Local embedding model (Transformers.js, runs in-process, no API key, $0).
# Weights are pre-downloaded into the Docker image at build time.
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
# Parent Document Retrieval: small child chunks for precise matching, large
# parent chunks returned to the LLM for context.
CHILD_CHUNK_SIZE=400
PARENT_CHUNK_SIZE=2000
# How many parent documents to retrieve per query.
RETRIEVER_TOP_K=3
# Hard cap on diff size (approx tokens) before truncation kicks in. Kept modest
# so a single call fits Groq's free-tier per-minute token budget (~8k TPM).
MAX_DIFF_TOKENS=2500

# --- Rate limiting (free tier) -----------------------------------------------
# Milliseconds to wait between LLM calls in the eval harness so the per-minute
# token bucket refills. Set to 0 on a paid tier.
EVAL_THROTTLE_MS=60000

# --- Observability (optional) ------------------------------------------------
# LangSmith tracing. Free account: https://smith.langchain.com
# Leave LANGSMITH_TRACING=false to rely on the built-in local JSONL trace logger.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pr-review-assistant

# --- Runtime -----------------------------------------------------------------
# info | debug  — `debug` writes structured JSONL traces to docs/evidence/.
LOG_LEVEL=info

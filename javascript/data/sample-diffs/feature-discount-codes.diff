+/**
+ * Looks up a discount code by its code string, validates it is still usable,
+ * and returns the DiscountCode record.
+ */
+async function resolveDiscountCode(code: string): Promise<DiscountCode> {
+  const { rows } = await query<DiscountCode>(
+    `SELECT id, code, type, value, max_uses AS "maxUses", used_count AS "usedCount", expires_at AS "expiresAt"
+     FROM discount_codes
+     WHERE code = $1`,
+    [code],
+  );
+
+  if (rows.length === 0) {
+    throw new AppError('DISCOUNT_CODE_NOT_FOUND', 404, `Discount code '${code}' not found`);
+  }
+
+  const dc = rows[0];
+
+  if (dc.expiresAt !== null && dc.expiresAt < new Date()) {
+    throw new AppError('DISCOUNT_CODE_EXPIRED', 400, 'This discount code has expired');
+  }
+
+  if (dc.usedCount >= dc.maxUses) {
+    throw new AppError('DISCOUNT_CODE_EXHAUSTED', 400, 'This discount code has reached its usage limit');
+  }
+
+  return dc;
+}
+
+/**
+ * Calculates the discount amount in cents given a discount code and order subtotal.
+ * Returns the number of cents to subtract (never more than the order total).
+ */
+function applyDiscount(discountCode: DiscountCode, subtotalCents: number): number {
+  let discountCents: number;
+
+  if (discountCode.type === 'percentage') {
+    discountCents = Math.round((subtotalCents * discountCode.value) / 100);
+  } else {
+    discountCents = discountCode.value;
+  }
+
+  // Never discount below zero
+  return Math.min(discountCents, subtotalCents);
+}
+

@@ -0,0 +1,40 @@
+import { Router, Request, Response, NextFunction } from 'express';
+import { requireAuth } from '../authMiddleware';
+import { AuthenticatedRequest } from '../authMiddleware';
+import { createOrder, createOrderSchema } from '../orderService';
+import { AppError } from '../errors';
+
+const router = Router();
+
+/**
+ * POST /orders
+ * Creates a new order for the authenticated customer.
+ * Optionally accepts a discountCode in the request body.
+ */
+router.post('/', requireAuth, async (req: Request, res: Response, next: NextFunction) => {
+  try {
+    const parsed = createOrderSchema.safeParse({
+      ...req.body,
+      customerId: (req as AuthenticatedRequest).user?.id,
+    });
+
+    if (!parsed.success) {
+      const details = parsed.error.errors.map((e) => ({
+        field: e.path.join('.'),
+        issue: e.message,
+      }));
+      next(new AppError('VALIDATION_ERROR', 400, 'Invalid request body'));
+      return;
+    }
+
+    const order = await createOrder(parsed.data);
+
+    res.status(201).json({ data: order });
+  } catch (err) {
+    next(err);
+  }
+});
+
+export default router;

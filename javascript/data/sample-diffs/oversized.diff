+import { z } from 'zod';
+import { query } from './db';
+import { AppError } from './errors';
+import { logger } from './logger';
+
+export const createProductSchema = z.object({
+  name: z.string().min(1).max(200),
+  priceCents: z.number().int().positive(),
+  category: z.string().min(1),
+  description: z.string().optional(),
+  sku: z.string().min(1).max(50),
+  stockQuantity: z.number().int().min(0).default(0),
+}).strict();
+
+export const updateProductSchema = createProductSchema.partial();
+
+export type CreateProductInput = z.infer<typeof createProductSchema>;
+export type UpdateProductInput = z.infer<typeof updateProductSchema>;
+
+export interface Product {
+  id: string;
+  name: string;
+  priceCents: number;
+  category: string;
+  description: string | null;
+  sku: string;
+  stockQuantity: number;
+  createdAt: Date;
+  updatedAt: Date;
+}
+
+export async function listProducts(queryParams: Record<string, unknown>): Promise<{ data: Product[]; meta: object }> {
+  const page = parseInt(String(queryParams.page ?? '1'), 10);
+  const limit = Math.min(parseInt(String(queryParams.limit ?? '20'), 10), 100);
+  const offset = (page - 1) * limit;
+  const category = queryParams.category ? String(queryParams.category) : null;
+
+  const params: unknown[] = [limit, offset];
+  const where = category ? `WHERE category = $3` : '';
+  if (category) params.push(category);
+
+  const { rows } = await query<Product>(
+    `SELECT id, name, price_cents AS "priceCents", category, description, sku,
+            stock_quantity AS "stockQuantity", created_at AS "createdAt", updated_at AS "updatedAt"
+     FROM products ${where} ORDER BY name LIMIT $1 OFFSET $2`,
+    params,
+  );
+
+  const countResult = await query<{ count: string }>(
+    `SELECT COUNT(*) AS count FROM products ${where}`,
+    category ? [category] : [],
+  );
+
+  return {
+    data: rows,
+    meta: { page, limit, total: parseInt(countResult.rows[0].count, 10) },
+  };
+}
+
+export async function getProduct(id: string): Promise<Product> {
+  const { rows } = await query<Product>(
+    `SELECT id, name, price_cents AS "priceCents", category, description, sku,
+            stock_quantity AS "stockQuantity", created_at AS "createdAt", updated_at AS "updatedAt"
+     FROM products WHERE id = $1`,
+    [id],
+  );
+  if (rows.length === 0) {
+    throw new AppError('PRODUCT_NOT_FOUND', 404, `Product ${id} not found`);
+  }
+  return rows[0];
+}
+
+export async function createProduct(body: unknown): Promise<Product> {
+  const parsed = createProductSchema.safeParse(body);
+  if (!parsed.success) {
+    throw new AppError('VALIDATION_ERROR', 400, 'Invalid product data');
+  }
+  const d = parsed.data;
+  const { rows } = await query<Product>(
+    `INSERT INTO products (name, price_cents, category, description, sku, stock_quantity)
+     VALUES ($1, $2, $3, $4, $5, $6)
+     RETURNING id, name, price_cents AS "priceCents", category, description, sku,
+             stock_quantity AS "stockQuantity", created_at AS "createdAt", updated_at AS "updatedAt"`,
+    [d.name, d.priceCents, d.category, d.description ?? null, d.sku, d.stockQuantity],
+  );
+  logger.info({ productId: rows[0].id }, 'Product created');
+  return rows[0];
+}
+
+export async function updateProduct(id: string, body: unknown): Promise<Product> {
+  const parsed = updateProductSchema.safeParse(body);
+  if (!parsed.success) {
+    throw new AppError('VALIDATION_ERROR', 400, 'Invalid product update data');
+  }
+  const d = parsed.data;
+  const setClauses: string[] = [];
+  const params: unknown[] = [];
+  if (d.name !== undefined) { params.push(d.name); setClauses.push(`name = $${params.length}`); }
+  if (d.priceCents !== undefined) { params.push(d.priceCents); setClauses.push(`price_cents = $${params.length}`); }
+  if (d.category !== undefined) { params.push(d.category); setClauses.push(`category = $${params.length}`); }
+  if (d.description !== undefined) { params.push(d.description); setClauses.push(`description = $${params.length}`); }
+  if (d.sku !== undefined) { params.push(d.sku); setClauses.push(`sku = $${params.length}`); }
+  if (d.stockQuantity !== undefined) { params.push(d.stockQuantity); setClauses.push(`stock_quantity = $${params.length}`); }
+  if (setClauses.length === 0) {
+    return getProduct(id);
+  }
+  params.push(id);
+  const { rows } = await query<Product>(
+    `UPDATE products SET ${setClauses.join(', ')}, updated_at = NOW()
+     WHERE id = $${params.length}
+     RETURNING id, name, price_cents AS "priceCents", category, description, sku,
+             stock_quantity AS "stockQuantity", created_at AS "createdAt", updated_at AS "updatedAt"`,
+    params,
+  );
+  if (rows.length === 0) {
+    throw new AppError('PRODUCT_NOT_FOUND', 404, `Product ${id} not found`);
+  }
+  logger.info({ productId: id }, 'Product updated');
+  return rows[0];
+}
+
+export async function deleteProduct(id: string): Promise<void> {
+  const { rowCount } = await query(
+    'DELETE FROM products WHERE id = $1',
+    [id],
+  );
+  if (!rowCount || rowCount === 0) {
+    throw new AppError('PRODUCT_NOT_FOUND', 404, `Product ${id} not found`);
+  }
+  logger.info({ productId: id }, 'Product deleted');
+}

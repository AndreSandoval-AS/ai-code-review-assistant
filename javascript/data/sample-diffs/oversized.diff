+import { Router, Response, NextFunction } from 'express';
+import { requireAuth, requireAdmin, AuthenticatedRequest } from '../authMiddleware';
+import {
+  getStockLevel,
+  adjustStock,
+  adjustStockSchema,
+  getLowStockProducts,
+  getStockHistory,
+  getInventoryValueCents,
+  getOutOfStockProducts,
+  getCategoryStockSummary,
+} from '../inventoryService';
+import { AppError } from '../errors';
+
+const router = Router();
+
+/** GET /inventory/:productId/stock — get current stock level */
+router.get('/:productId/stock', requireAuth, requireAdmin, async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
+  try {
+    const level = await getStockLevel(req.params.productId);
+    res.json({ data: { stockQuantity: level } });
+  } catch (err) { next(err); }
+});
+
+/** POST /inventory/:productId/adjust — adjust stock up or down */
+router.post('/:productId/adjust', requireAuth, requireAdmin, async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
+  try {
+    const parsed = adjustStockSchema.safeParse({ ...req.body, productId: req.params.productId });
+    if (!parsed.success) {
+      next(new AppError('VALIDATION_ERROR', 400, 'Invalid stock adjustment data'));
+      return;
+    }
+    const adjustment = await adjustStock(parsed.data, req.user!.id);
+    res.status(201).json({ data: adjustment });
+  } catch (err) { next(err); }
+});
+
+/** GET /inventory/:productId/history — stock adjustment history */
+router.get('/:productId/history', requireAuth, requireAdmin, async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
+  try {
+    const page = parseInt(String(req.query.page ?? '1'), 10);
+    const limit = parseInt(String(req.query.limit ?? '50'), 10);
+    const result = await getStockHistory(req.params.productId, page, limit);
+    res.json(result);
+  } catch (err) { next(err); }
+});
+
+/** GET /inventory/low-stock — products with stock at or below threshold */
+router.get('/low-stock', requireAuth, requireAdmin, async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
+  try {
+    const threshold = parseInt(String(req.query.threshold ?? '5'), 10);
+    const products = await getLowStockProducts(threshold);
+    res.json({ data: products });
+  } catch (err) { next(err); }
+});
+
+/** GET /inventory/out-of-stock — products with zero stock */
+router.get('/out-of-stock', requireAuth, requireAdmin, async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
+  try {
+    const products = await getOutOfStockProducts();
+    res.json({ data: products });
+  } catch (err) { next(err); }
+});
+
+/** GET /inventory/value — total inventory value in cents */
+router.get('/value', requireAuth, requireAdmin, async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
+  try {
+    const valueCents = await getInventoryValueCents();
+    res.json({ data: { valueCents, valueDollars: (valueCents / 100).toFixed(2) } });
+  } catch (err) { next(err); }
+});
+
+/** GET /inventory/category-summary — stock counts by tire category */
+router.get('/category-summary', requireAuth, requireAdmin, async (req: AuthenticatedRequest, res: Response, next: NextFunction) => {
+  try {
+    const summary = await getCategoryStockSummary();
+    res.json({ data: summary });
+  } catch (err) { next(err); }
+});
+
+export default router;


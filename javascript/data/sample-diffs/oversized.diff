@@ -0,0 +1,174 @@
+import { z } from 'zod';
+import { query, getClient } from './db';
+import { AppError } from './errors';
+import { logger } from './logger';
+
+export interface StockAdjustment {
+  id: string;
+  productId: string;
+  delta: number;
+  reason: string;
+  createdBy: string;
+  createdAt: Date;
+}
+
+export const adjustStockSchema = z.object({
+  productId: z.string().uuid(),
+  delta: z.number().int(),
+  reason: z.string().min(1).max(500),
+}).strict();
+
+export type AdjustStockInput = z.infer<typeof adjustStockSchema>;
+
+export async function getStockLevel(productId: string): Promise<number> {
+  const { rows } = await query<{ stock_quantity: number }>(
+    'SELECT stock_quantity FROM products WHERE id = $1',
+    [productId],
+  );
+  if (rows.length === 0) {
+    throw new AppError('PRODUCT_NOT_FOUND', 404, `Product ${productId} not found`);
+  }
+  return rows[0].stock_quantity;
+}
+
+export async function adjustStock(input: AdjustStockInput, adminId: string): Promise<StockAdjustment> {
+  const client = await getClient();
+  try {
+    await client.query('BEGIN');
+
+    const { rows: productRows } = await client.query<{ stock_quantity: number }>(
+      'SELECT stock_quantity FROM products WHERE id = $1 FOR UPDATE',
+      [input.productId],
+    );
+    if (productRows.length === 0) {
+      throw new AppError('PRODUCT_NOT_FOUND', 404, `Product ${input.productId} not found`);
+    }
+
+    const currentStock = productRows[0].stock_quantity;
+    const newStock = currentStock + input.delta;
+    if (newStock < 0) {
+      throw new AppError('INSUFFICIENT_STOCK', 400, `Cannot reduce stock below 0 (current: ${currentStock})`);
+    }
+
+    await client.query(
+      'UPDATE products SET stock_quantity = $1, updated_at = NOW() WHERE id = $2',
+      [newStock, input.productId],
+    );
+
+    const { rows } = await client.query<StockAdjustment>(
+      `INSERT INTO stock_adjustments (product_id, delta, reason, created_by)
+       VALUES ($1, $2, $3, $4)
+       RETURNING id, product_id AS "productId", delta, reason, created_by AS "createdBy", created_at AS "createdAt"`,
+      [input.productId, input.delta, input.reason, adminId],
+    );
+
+    await client.query('COMMIT');
+    logger.info({ productId: input.productId, delta: input.delta, adminId }, 'Stock adjusted');
+    return rows[0];
+  } catch (err) {
+    await client.query('ROLLBACK');
+    throw err;
+  } finally {
+    client.release();
+  }
+}
+
+export async function getLowStockProducts(threshold = 5): Promise<Array<{ id: string; name: string; sku: string; stockQuantity: number }>> {
+  const { rows } = await query<{ id: string; name: string; sku: string; stockQuantity: number }>(
+    `SELECT id, name, sku, stock_quantity AS "stockQuantity"
+     FROM products
+     WHERE stock_quantity <= $1
+     ORDER BY stock_quantity ASC`,
+    [threshold],
+  );
+  return rows;
+}
+
+export async function getStockHistory(productId: string, page = 1, limit = 50): Promise<{ data: StockAdjustment[]; meta: object }> {
+  const offset = (page - 1) * limit;
+  const { rows } = await query<StockAdjustment>(
+    `SELECT id, product_id AS "productId", delta, reason, created_by AS "createdBy", created_at AS "createdAt"
+     FROM stock_adjustments
+     WHERE product_id = $1
+     ORDER BY created_at DESC
+     LIMIT $2 OFFSET $3`,
+    [productId, limit, offset],
+  );
+  const countResult = await query<{ count: string }>(
+    'SELECT COUNT(*) AS count FROM stock_adjustments WHERE product_id = $1',
+    [productId],
+  );
+  return {
+    data: rows,
+    meta: { page, limit, total: parseInt(countResult.rows[0].count, 10) },
+  };
+}
+
+export async function reserveStock(productId: string, quantity: number): Promise<void> {
+  const client = await getClient();
+  try {
+    await client.query('BEGIN');
+    const { rows } = await client.query<{ stock_quantity: number }>(
+      'SELECT stock_quantity FROM products WHERE id = $1 FOR UPDATE',
+      [productId],
+    );
+    if (rows.length === 0) {
+      throw new AppError('PRODUCT_NOT_FOUND', 404, `Product ${productId} not found`);
+    }
+    if (rows[0].stock_quantity < quantity) {
+      throw new AppError('INSUFFICIENT_STOCK', 400, `Insufficient stock for product ${productId}`);
+    }
+    await client.query(
+      'UPDATE products SET stock_quantity = stock_quantity - $1, updated_at = NOW() WHERE id = $2',
+      [quantity, productId],
+    );
+    await client.query('COMMIT');
+  } catch (err) {
+    await client.query('ROLLBACK');
+    throw err;
+  } finally {
+    client.release();
+  }
+}
+
+export async function releaseStock(productId: string, quantity: number): Promise<void> {
+  await query(
+    'UPDATE products SET stock_quantity = stock_quantity + $1, updated_at = NOW() WHERE id = $2',
+    [quantity, productId],
+  );
+  logger.info({ productId, quantity }, 'Stock released');
+}
+
+// ============================================================
+// Additional inventory report helpers
+// ============================================================
+
+export async function getInventoryValueCents(): Promise<number> {
+  const { rows } = await query<{ total: string }>(
+    'SELECT COALESCE(SUM(price_cents * stock_quantity), 0) AS total FROM products',
+    [],
+  );
+  return parseInt(rows[0].total, 10);
+}
+
+export async function getOutOfStockProducts(): Promise<Array<{ id: string; name: string; sku: string }>> {
+  const { rows } = await query<{ id: string; name: string; sku: string }>(
+    `SELECT id, name, sku FROM products WHERE stock_quantity = 0 ORDER BY name`,
+    [],
+  );
+  return rows;
+}
+
+export async function getCategoryStockSummary(): Promise<Array<{ category: string; totalUnits: number; productCount: number }>> {
+  const { rows } = await query<{ category: string; totalUnits: number; productCount: number }>(
+    `SELECT category,
+            SUM(stock_quantity)::int AS "totalUnits",
+            COUNT(*)::int AS "productCount"
+     FROM products
+     GROUP BY category
+     ORDER BY category`,
+    [],
+  );
+  return rows;
+}
+


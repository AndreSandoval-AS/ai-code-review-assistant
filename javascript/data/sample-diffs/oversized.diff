+
+// ============================================================
+// Cart Service — manages the shopping cart for a customer
+// ============================================================
+
+export interface CartItem {
+  id: string;
+  customerId: string;
+  productId: string;
+  quantity: number;
+  addedAt: Date;
+  product?: Product;
+}
+
+export async function getCart(customerId: string): Promise<CartItem[]> {
+  const { rows } = await query<CartItem>(
+    `SELECT ci.id, ci.customer_id AS "customerId", ci.product_id AS "productId",
+            ci.quantity, ci.added_at AS "addedAt",
+            p.name AS "productName", p.price_cents AS "priceCents"
+     FROM cart_items ci
+     JOIN products p ON p.id = ci.product_id
+     WHERE ci.customer_id = $1
+     ORDER BY ci.added_at ASC`,
+    [customerId],
+  );
+  return rows;
+}
+
+export async function addToCart(customerId: string, productId: string, quantity: number): Promise<CartItem> {
+  // Verify product exists
+  await getProduct(productId);
+
+  // Upsert: if item already in cart, increase quantity
+  const { rows } = await query<CartItem>(
+    `INSERT INTO cart_items (customer_id, product_id, quantity)
+     VALUES ($1, $2, $3)
+     ON CONFLICT (customer_id, product_id)
+     DO UPDATE SET quantity = cart_items.quantity + EXCLUDED.quantity,
+                   updated_at = NOW()
+     RETURNING id, customer_id AS "customerId", product_id AS "productId",
+             quantity, added_at AS "addedAt"`,
+    [customerId, productId, quantity],
+  );
+  logger.info({ customerId, productId, quantity }, 'Item added to cart');
+  return rows[0];
+}
+
+export async function updateCartItem(customerId: string, cartItemId: string, quantity: number): Promise<CartItem> {
+  if (quantity <= 0) {
+    return removeFromCart(customerId, cartItemId);
+  }
+  const { rows } = await query<CartItem>(
+    `UPDATE cart_items SET quantity = $1, updated_at = NOW()
+     WHERE id = $2 AND customer_id = $3
+     RETURNING id, customer_id AS "customerId", product_id AS "productId",
+             quantity, added_at AS "addedAt"`,
+    [quantity, cartItemId, customerId],
+  );
+  if (rows.length === 0) {
+    throw new AppError('CART_ITEM_NOT_FOUND', 404, `Cart item ${cartItemId} not found`);
+  }
+  return rows[0];
+}
+
+export async function removeFromCart(customerId: string, cartItemId: string): Promise<CartItem> {
+  const { rows } = await query<CartItem>(
+    `DELETE FROM cart_items WHERE id = $1 AND customer_id = $2
+     RETURNING id, customer_id AS "customerId", product_id AS "productId",
+             quantity, added_at AS "addedAt"`,
+    [cartItemId, customerId],
+  );
+  if (rows.length === 0) {
+    throw new AppError('CART_ITEM_NOT_FOUND', 404, `Cart item ${cartItemId} not found`);
+  }
+  logger.info({ customerId, cartItemId }, 'Item removed from cart');
+  return rows[0];
+}
+
+export async function clearCart(customerId: string): Promise<void> {
+  await query('DELETE FROM cart_items WHERE customer_id = $1', [customerId]);
+  logger.info({ customerId }, 'Cart cleared');
+}
+
+export async function cartTotal(customerId: string): Promise<number> {
+  const { rows } = await query<{ total: string }>(
+    `SELECT COALESCE(SUM(ci.quantity * p.price_cents), 0) AS total
+     FROM cart_items ci
+     JOIN products p ON p.id = ci.product_id
+     WHERE ci.customer_id = $1`,
+    [customerId],
+  );
+  return parseInt(rows[0].total, 10);
+}
+
+// ============================================================
+// Order query helpers
+// ============================================================
+
+export interface OrderSummary {
+  id: string;
+  customerId: string;
+  totalCents: number;
+  discountCents: number;
+  status: string;
+  itemCount: number;
+  createdAt: Date;
+}
+
+export async function getOrdersByCustomer(customerId: string, page = 1, limit = 20): Promise<{ data: OrderSummary[]; meta: object }> {
+  const offset = (page - 1) * limit;
+  const { rows } = await query<OrderSummary>(
+    `SELECT o.id, o.customer_id AS "customerId", o.total_cents AS "totalCents",
+            o.discount_cents AS "discountCents", o.status,
+            COUNT(oi.id)::int AS "itemCount", o.created_at AS "createdAt"
+     FROM orders o
+     LEFT JOIN order_items oi ON oi.order_id = o.id
+     WHERE o.customer_id = $1
+     GROUP BY o.id
+     ORDER BY o.created_at DESC
+     LIMIT $2 OFFSET $3`,
+    [customerId, limit, offset],
+  );
+  const countResult = await query<{ count: string }>(
+    'SELECT COUNT(*) AS count FROM orders WHERE customer_id = $1',
+    [customerId],
+  );
+  return {
+    data: rows,
+    meta: { page, limit, total: parseInt(countResult.rows[0].count, 10) },
+  };
+}
+
+export async function getOrderById(orderId: string, customerId?: string): Promise<OrderSummary> {
+  const params: unknown[] = [orderId];
+  const customerClause = customerId ? `AND o.customer_id = $2` : '';
+  if (customerId) params.push(customerId);
+  const { rows } = await query<OrderSummary>(
+    `SELECT o.id, o.customer_id AS "customerId", o.total_cents AS "totalCents",
+            o.discount_cents AS "discountCents", o.status,
+            COUNT(oi.id)::int AS "itemCount", o.created_at AS "createdAt"
+     FROM orders o
+     LEFT JOIN order_items oi ON oi.order_id = o.id
+     WHERE o.id = $1 ${customerClause}
+     GROUP BY o.id`,
+    params,
+  );
+  if (rows.length === 0) {
+    throw new AppError('ORDER_NOT_FOUND', 404, `Order ${orderId} not found`);
+  }
+  return rows[0];
+}
+
+export async function cancelOrder(orderId: string, customerId: string): Promise<OrderSummary> {
+  const order = await getOrderById(orderId, customerId);
+  if (order.status !== 'pending') {
+    throw new AppError('ORDER_CANNOT_CANCEL', 400, 'Only pending orders can be cancelled');
+  }
+  const { rows } = await query<OrderSummary>(
+    `UPDATE orders SET status = 'cancelled', updated_at = NOW()
+     WHERE id = $1
+     RETURNING id, customer_id AS "customerId", total_cents AS "totalCents",
+             discount_cents AS "discountCents", status, created_at AS "createdAt"`,
+    [orderId],
+  );
+  logger.info({ orderId, customerId }, 'Order cancelled');
+  return { ...rows[0], itemCount: order.itemCount };
+}
+
+export async function adminUpdateOrderStatus(orderId: string, newStatus: string): Promise<OrderSummary> {
+  const validStatuses = ['pending', 'confirmed', 'shipped', 'delivered', 'cancelled'];
+  if (!validStatuses.includes(newStatus)) {
+    throw new AppError('INVALID_STATUS', 400, `Status must be one of: ${validStatuses.join(', ')}`);
+  }
+  const { rows } = await query<OrderSummary>(
+    `UPDATE orders SET status = $1, updated_at = NOW()
+     WHERE id = $2
+     RETURNING id, customer_id AS "customerId", total_cents AS "totalCents",
+             discount_cents AS "discountCents", status, created_at AS "createdAt"`,
+    [newStatus, orderId],
+  );
+  if (rows.length === 0) {
+    throw new AppError('ORDER_NOT_FOUND', 404, `Order ${orderId} not found`);
+  }
+  logger.info({ orderId, newStatus }, 'Order status updated by admin');
+  // Re-fetch with item count
+  return getOrderById(orderId);
+}
+


{
  "name": "pr-review-assistant",
  "version": "1.0.0",
  "description": "AI PR / Code Review Assistant — RAG over code diffs + Jira tickets, built with LangChain.js (TypeScript). Course deliverable for GenAI & LangChain for JS Developers.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "eval": "tsx eval/run-eval.ts",
    "predownload": "tsx src/scripts/predownload.ts",
    "tdd": "tsx src/scripts/build-tdd.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@langchain/classic": "^1.0.0",
    "@langchain/community": "^1.0.0",
    "@langchain/core": "^1.2.0",
    "@langchain/google-genai": "^2.2.0",
    "@langchain/groq": "^1.3.0",
    "@langchain/textsplitters": "^1.0.0",
    "dotenv": "^16.4.5",
    "langchain": "^1.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
